# Mac/Windowsのシステムファイル
.DS_Store
Thumbs.db

# Python関連
__pycache__/
*.pyc
.ipynb_checkpoints/

# Condaや仮想環境のフォルダ
env/
venv/
*.env

# データとアウトプットを全て無視
data/*
!data/process_scripts/
output/
mlruns/
analysis/

# ファイル名が含まれるconfigを無視
src/config/*
*config.py

# ログファイルや一時ファイル
*.log
temp/

# 分析用ノートブックファイル
*.ipynb